+  /**
+   * Builds a display-only taxonomy section row to separate WP groups by abyz_taxonomy classification.
+   * Rendered as a non-interactive header row; no expander, no count.
+   */
+  public buildTaxonomySectionRow(section:TaxonomySectionRow, colspan:number):HTMLElement {
+    const row = document.createElement('tr');
+    row.classList.add('abyz-taxonomy-section-row', rowGroupClassName);
+    row.dataset.taxonomyCode = section.taxonomyCode;
+    row.setAttribute('aria-label', section.name);
+    row.innerHTML = `
+      <td colspan="${colspan}" class="abyz-taxonomy-section-cell -no-highlighting">
+        <div class="abyz-taxonomy-section--value">
+          <span class="abyz-taxonomy-section--icon icon-tag"></span>
+          <span class="abyz-taxonomy-section--name">${_.escape(section.name)}</span>
+        </div>
+      </td>
+    `;
+    section.element = row;
+    return row;
+  }
+
+  /**
+   * Returns true when the given row-like object is a TaxonomySectionRow.
+   */
+  public static isTaxonomySectionRow(row:unknown):row is TaxonomySectionRow {
+    return (
+      typeof row === 'object' && row !== null &&
+      (row as TaxonomySectionRow).kind === TAXONOMY_SECTION_ROW_KIND
+    );
+  }
